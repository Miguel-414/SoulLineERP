# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=CONTROL_INVENTARIO
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña

# JWT — genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_por_una_clave_segura_y_larga
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS — Dominios permitidos (IMPORTANTE para producción, no usar "*")
# En desarrollo: ["http://localhost:5173", "http://localhost:3000"]
# En producción: ["https://tudominio.com", "https://app.tudominio.com"]
# Se pasa como JSON string
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "http://127.0.0.1:5173"]
CORS_CREDENTIALS=true

# App
PROJECT_NAME="Control Inventario API"

# Administrador maestro — se crea automáticamente si la BD está vacía.
# Cambia estas credenciales en .env antes del primer despliegue.
MASTER_ADMIN_USERNAME="superadmin"
MASTER_ADMIN_PASSWORD="Admin1234!"
MASTER_ADMIN_EMAIL="admin@soulline.com"